{
  "name": "panelpro-geometry-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic flat-sheet pre-press extraction worker for large-format print. Crops panel rectangles from a RestylePro multi-view master proof, sizes them to exact print pixels with absolute geometry, and mirror-extends the bleed — sharp/libvips only, no native OpenCV.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "axios": "^1.7.7",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5"
  },
  "optionalDependencies": {
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
