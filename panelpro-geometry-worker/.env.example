# ── Worker runtime ────────────────────────────────────────────────────────────
PORT=8080
# Shared secret expected in the `x-panelpro-signature` header of inbound webhooks.
# REQUIRED on a public host — when blank, the webhook accepts anonymous jobs.
WEBHOOK_SECRET=change-me

# ── Public HTTPS (Caddy reverse proxy) ────────────────────────────────────────
# Public hostname Caddy serves; its DNS A record must point at this host.
WORKER_DOMAIN=worker.yourdomain.com
# Optional: email for Let's Encrypt cert-expiry notices (see Caddyfile).
ACME_EMAIL=

# ── Supabase (infrastructure connector) ───────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service-role key — this worker runs in a trusted, memory-unconstrained container,
# never in the browser/edge. Keep it out of any frontend bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_OUTPUT_BUCKET=print-assets

# ── Cloudflare R2 (optional storage backend; no 50MB cap, free tier) ──────────
# When these are set the worker uses R2 instead of Supabase for print files.
# Create an R2 bucket + an API token (Object Read & Write) in the Cloudflare
# dashboard, then fill these in.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=print-assets
# Optional: override the S3 endpoint (defaults to the account's R2 endpoint).
R2_ENDPOINT=

# ── Geometry baselines (RestylePro compatible) ────────────────────────────────
# Overridable, but the panel JSON manifest is always authoritative when present.
DEFAULT_DPI=150
DEFAULT_BLEED_INCHES=5

# OCR 1:1 text check in the QC gate. Best-effort: if tesseract.js can't run it
# is skipped, never failing a job. Set to false to disable entirely.
ENFORCE_OCR=true
