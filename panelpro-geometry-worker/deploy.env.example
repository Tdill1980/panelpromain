# Copy this to `deploy.env` (which is git-ignored) and fill in your real values.
# deploy.sh ships this file to the Droplet as the worker's .env over SSH.
# NEVER commit deploy.env — it holds your Supabase service_role key.

PORT=8080
SUPABASE_URL=https://xvsfqqcbrbfhjmxjrlnj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-real-service-role-key-here
SUPABASE_OUTPUT_BUCKET=print-assets

# The console's "Webhook secret" must match this.
WEBHOOK_SECRET=PanelPro2026

# Only needed if you also boot the Caddy TLS proxy (COMPOSE_SERVICES="").
WORKER_DOMAIN=worker.yourdomain.com

DEFAULT_DPI=150
DEFAULT_BLEED_INCHES=5
